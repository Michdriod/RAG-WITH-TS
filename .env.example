# Groq API Key - Get it from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API Token - Get it from https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Pinecone API Key - Get it from https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone Index Name - Your Pinecone index name
PINECONE_INDEX_NAME=your_index_name_here

# Pinecone Environment - Your Pinecone environment (e.g., us-east-1)
PINECONE_ENVIRONMENT=your_environment_here

# Pinecone Namespace - Your Pinecone namespace (default: __default__)
PINECONE_NAMESPACE=__default__

# API Configuration
PORT=3000
CORS_ORIGIN=*
